ninja_required_version = 1.3
cxx = c++
nvcc = /work/pi_rsitaram_umass_edu/tungi/cuda-12.6/bin/nvcc

cflags = -fno-strict-overflow -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/include -fPIC -O2 -isystem /work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/include -fPIC -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/lib/python3.12/site-packages/torch/include -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/work/pi_rsitaram_umass_edu/tungi/cuda-12.6/include -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/include/python3.12 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1016"' -DTORCH_EXTENSION_NAME=inference_extensions_cuda -D_GLIBCXX_USE_CXX11_ABI=1 -std=c++17
cuda_cflags = -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/lib/python3.12/site-packages/torch/include -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/work/pi_rsitaram_umass_edu/tungi/cuda-12.6/include -I/work/pi_rsitaram_umass_edu/tungi/conda/envs/dcvc/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math --extra-device-vectorization -arch=native -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1016"' -DTORCH_EXTENSION_NAME=inference_extensions_cuda -D_GLIBCXX_USE_CXX11_ABI=1 -ccbin /modules/spack/packages/linux-ubuntu24.04-x86_64_v3/gcc-13.2.0/gcc-9.4.0-ctk4n3223pjnwfvyn6crmzo4isburta7/bin/gcc -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/bind.o: compile /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/bind.cpp
build /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/impl.o: compile /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/impl.cpp
build /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/kernel.o: cuda_compile /work/pi_rsitaram_umass_edu/tungi/DCVC/src/layers/extensions/inference/kernel.cu








